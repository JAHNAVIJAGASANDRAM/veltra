{
  "name": "veltra",
  "version": "0.1.0",
  "private": true,
  "description": "Veltra Secure Collaborative Workspace monorepo.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev": "pnpm --filter @veltra/api run dev",
    "dev:api": "pnpm --filter @veltra/api run dev",
    "dev:web": "pnpm --filter @veltra/web run dev",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down --remove-orphans"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
