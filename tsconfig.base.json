{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@veltra/config": ["packages/config/src/index.ts"],
      "@veltra/contracts": ["packages/contracts/src/index.ts"],
      "@veltra/security": ["packages/security/src/index.ts"]
    }
  }
}
