# Runtime
NODE_ENV=development
APP_NAME=Veltra
API_PORT=5000
WEB_PORT=5173
PUBLIC_WEB_ORIGIN=http://localhost:5173

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=veltra
POSTGRES_USER=veltra
POSTGRES_PASSWORD=veltra_dev_password
DATABASE_URL=postgresql://veltra:veltra_dev_password@localhost:5432/veltra

# Redis
REDIS_URL=redis://localhost:6379

# Object storage compatible with S3; MinIO is used locally.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=veltra-files
S3_ACCESS_KEY=veltra
S3_SECRET_KEY=veltra_dev_secret

# Security
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
SESSION_COOKIE_NAME=veltra_session
COOKIE_SECRET=replace-with-32-plus-random-characters
JWT_PRIVATE_KEY_B64=replace-with-base64-encoded-private-key
JWT_PUBLIC_KEY_B64=replace-with-base64-encoded-public-key

# Observability
LOG_LEVEL=info
REQUEST_ID_HEADER=x-request-id
