{
  "name": "@veltra/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/apps/api/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/apps/api/src/server.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
